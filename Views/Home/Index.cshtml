<!-- ══════════════════
     03 — 訓練計畫
══════════════════ -->
<section id="sec-program">
    <div class="program-body">
        <div class="program-intro">
            <div>
                <div class="program-vertical">
                <p class="program-intro-desc">
                    輸入你的訓練目標、程度、每週天數與器材條件，系統自動根據科學化的週期化訓練原則，產生一份專屬週課表。
                </p>
                        <h2 class="program-intro-title">超える<br>限界は、<br>為目標而生</h2>
               </div>
            </div>
            <a asp-controller="Plan" asp-action="Index" class="muscle-cta">
                <span class="cta-slide-wrap">
                    <span class="cta-slide-a">立即產生計劃</span>
                   <span class="cta-slide-b">立即產生計劃</span>
                </span>
                <span class="cta-arrow-wrap">
                    <span class="cta-arrow-a">→</span>
                    <span class="cta-arrow-b">→</span>
                </span>
            </a>
        </div>
        <a asp-controller="Plan" asp-action="Index" asp-route-goal="hypertrophy" class="program-card dark">
            <div>
                <span class="program-type">目標 01</span>
                <h3 class="program-name">增肌</h3>
                <p class="program-jp">Hypertrophy</p>
                <p class="program-detail">8–12 次 × 4 組<br>中等重量 · 高容量<br>週 4 天訓練</p>
            </div>
            <div class="program-arrow">
                <span class="program-arrow-line"></span>
                查看計畫
            </div>
        </a>
        <a asp-controller="Plan" asp-action="Index" asp-route-goal="strength" class="program-card dark">
            <div>
                <span class="program-type">目標 02</span>
                <h3 class="program-name">增力</h3>
                <p class="program-jp">Strength</p>
                <p class="program-detail">3–5 次 × 5 組<br>大重量 · 低容量<br>週 3 天訓練</p>
            </div>
            <div class="program-arrow">
                <span class="program-arrow-line"></span>
                查看計畫
            </div>
        </a>
        <a asp-controller="Plan" asp-action="Index" asp-route-goal="fatloss" class="program-card dark">
            <div>
                <span class="program-type">目標 03</span>
                <h3 class="program-name">減脂</h3>
                <p class="program-jp">Fat Loss</p>
                <p class="program-detail">15–20 次 × 3 組<br>輕重量 · 超高容量<br>週 5 天訓練</p>
            </div>
            <div class="program-arrow">
                <span class="program-arrow-line"></span>
                查看計畫
            </div>
        </a>
    </div>
</section>

<!-- ══════════════════
     05 — 訓練日誌
══════════════════ -->
<section id="sec-log">
    <div class="log-body">
        <div class="log-left">
            <a asp-controller="TrainingLog" asp-action="Index" class="log-item">
                <div class="log-item-left">
                    <span class="log-item-num">01</span>
                    <span class="log-item-name">日曆視圖</span>
                </div>
                <span class="log-item-en">Calendar View</span>
            </a>
            <a asp-controller="TrainingLog" asp-action="Index" class="log-item">
                <div class="log-item-left">
                    <span class="log-item-num">02</span>
                    <span class="log-item-name">動作記錄</span>
                </div>
                <span class="log-item-en">Exercise Log</span>
            </a>
            <a asp-controller="TrainingLog" asp-action="Index" class="log-item">
                <div class="log-item-left">
                    <span class="log-item-num">03</span>
                    <span class="log-item-name">進度追蹤</span>
                </div>
                <span class="log-item-en">Progress Track</span>
            </a>
            <a asp-controller="TrainingLog" asp-action="Index" class="log-item">
                <div class="log-item-left">
                    <span class="log-item-num">04</span>
                    <span class="log-item-name">訓練統計</span>
                </div>
                <span class="log-item-en">Training Stats</span>
            </a>
            <a asp-controller="TrainingLog" asp-action="Index" class="log-item">
                <div class="log-item-left">
                    <span class="log-item-num">05</span>
                    <span class="log-item-name">肌群分析</span>
                </div>
                <span class="log-item-en">Muscle Analysis</span>
            </a>
        </div>
        <div class="log-right">
            <div>
                <p class="log-eyebrow">Training Log</p>
                <h2 class="log-headline">記錄<br>每一次<br>突破</h2>
                <p class="log-desc">
                    完整記錄每次訓練的動作、重量與組數。搭配日曆視圖，讓你清楚掌握訓練節奏，追蹤每一個進步。
                </p>
            </div>
            <a asp-controller="TrainingLog" asp-action="Index" class="nutrition-cta">
                <span class="cta-slide-wrap">
                    <span class="cta-slide-a">開始記錄訓練</span>
                    <span class="cta-slide-b">開始記錄訓練</span>
                </span>
                <span class="cta-arrow-wrap">
                    <span class="cta-arrow-a">→</span>
                    <span class="cta-arrow-b">→</span>
                </span>
            </a>
        </div>
    </div>
</section>

<!-- ══════════════════
     04 — 飲食計算
══════════════════ -->
<section id="sec-nutrition">
    <div class="sec-header">
        <span class="sec-title"></span>
    </div>
    <div class="nutrition-body">
        <div class="nutrition-left">
            <div>
                <p class="nutrition-eyebrow">Nutrition Tracking</p>
                <h2 class="nutrition-headline">                   
                    以食塑形
                </h2>
                <p class="nutrition-desc">
                    搜尋食物資料庫、記錄今日攝取、追蹤三大巨量營養素與微量元素。搭配 TDEE 計算器，讓每一口都符合你的目標。
                </p>
            </div>
            <a asp-controller="Nutrition" asp-action="Index" class="nutrition-cta">
                <span class="cta-slide-wrap">
                    <span class="cta-slide-a">記錄今日飲食</span>
                    <span class="cta-slide-b">記錄今日飲食</span>
                </span>
                <span class="cta-arrow-wrap">
                    <span class="cta-arrow-a">→</span>
                    <span class="cta-arrow-b">→</span>
                </span>
            </a>
        </div>
        <div class="nutrition-right">
            <div class="nutrition-stat">
                <div>
                    <span class="nutrition-stat-num">15</span>
                    <span class="nutrition-stat-unit">種食物</span>
                </div>
                <span class="nutrition-stat-desc">常見食物資料庫</span>
            </div>
            <div class="nutrition-stat">
                <div>
                    <span class="nutrition-stat-num">7</span>
                    <span class="nutrition-stat-unit">項指標</span>
                </div>
                <span class="nutrition-stat-desc">熱量 · 蛋白質 · 碳水 · 脂肪 · 纖維 · 鈉 · 鐵</span>
            </div>
            <div class="nutrition-stat">
                <div>
                    <span class="nutrition-stat-num">5</span>
                    <span class="nutrition-stat-unit">餐</span>
                </div>
                <span class="nutrition-stat-desc">預設標準訓練飲食計畫</span>
            </div>
            <div class="nutrition-stat">
                <div>
                    <span class="nutrition-stat-num">BMI</span>
                </div>
                <span class="nutrition-stat-desc">+ TDEE 每日熱量計算器</span>
            </div>
        </div>
    </div>
</section>

