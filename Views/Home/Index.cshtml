@{
    ViewBag.Title = "KATACHI首頁";
}

@section styles {
    <link rel="stylesheet" href="~/css/kt-index.css" asp-append-version="true" />
	
}

@section scripts
{
    <script src="~/js/index.js" defer></script>
}
<!-- G 過場遮罩：上下兩半，動畫結束後分開 -->
    <div id="transition-top"></div>
    <div id="transition-bot"></div>


    <!-- ══════════════════════
       INTRO SCREEN
       動畫跑完前蓋住畫面
  ══════════════════════ -->
    <div id="intro-screen">
        <div class="logo-wrap">

            <!-- KATACHI 字母動畫 -->
            <div class="brand-name">
                <span class="letter">K</span>
                <span class="letter">A</span>
                <span class="letter">T</span>
                <span class="letter">A</span>
                <span class="letter">C</span>
                <span class="letter">H</span>
                <span class="letter dumbbell-i">
                    <svg viewBox="0 0 31 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                        <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                        <rect x="11" y="20" width="6" height="40" rx="0" fill="currentColor" />
                        <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                        <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
                    </svg>
                </span>
            </div>

            <!-- 副標題 -->
            <div class="brand-sub">Training Encyclopedia</div>
            <div class="brand-jp">形 · 重訓訓練百科</div>

        </div>
    </div>

<!-- ══════════════════════
       首頁內容
       intro 結束後淡入
  ══════════════════════ -->
<div id="home-content">

    <!-- HERO -->
    <section id="hero">
        <!-- <p class="hero-kicker">重訓訓練百科</p> -->
        <h1 class="hero-title">
            KATACH<span class="dumbbell-i">
            <svg viewBox="0 0 31 90" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                <rect x="11" y="20" width="6" height="40" fill="currentColor" />
                <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
            </svg>
        </span>
    </h1>
    <p class="hero-sub">形 · Training Encyclopedia</p>

    <div class="scroll-indicator">
        <span class="scroll-text">Scroll</span>
        <div class="scroll-line">
            <div class="scroll-dot"></div>
        </div>
    </div>
</section>


<!-- 後續 section 佔位（之後一步步加入） -->
<!-- ══════════════════
     01 — 肌肉百科
══════════════════ -->

<section id="sec-muscle">
    <div class="muscle-body">
        <div class="muscle-left">
            <div>
                <p class="muscle-eyebrow">Muscle Wiki</p>
                <h2 class="muscle-headline">
                    <span>了解你的身體</span>
                    身體圖鑑
                </h2>
                <p class="muscle-desc">
                    從胸到腿，每個肌群的解剖位置、訓練功能、常見弱點，都有完整的圖解說明。訓練之前，先認識自己的身體。
                </p>
            </div>
            <a asp-controller="MuscleMap" asp-action="Index" class="muscle-cta">
                <span class="cta-slide-wrap">
                    <span class="cta-slide-a">查看人體地圖</span>
                    <span class="cta-slide-b">查看人體地圖</span>
                </span>
                <span class="cta-arrow-wrap">
                    <span class="cta-arrow-a">→</span>
                    <span class="cta-arrow-b">→</span>
                </span>
            </a>
        </div>
        <div class="muscle-right">
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="chest" class="muscle-part">
                <span class="muscle-part-name">胸大肌</span>
                <span class="muscle-part-en">Pectoralis Major</span>
                <span class="muscle-part-num">04 個動作</span>
            </a>
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="lats" class="muscle-part">
                <span class="muscle-part-name">背闊肌</span>
                <span class="muscle-part-en">Latissimus Dorsi</span>
                <span class="muscle-part-num">03 個動作</span>
            </a>
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="quads" class="muscle-part">
                <span class="muscle-part-name">股四頭肌</span>
                <span class="muscle-part-en">Quadriceps</span>
                <span class="muscle-part-num">03 個動作</span>
            </a>
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="frontDeltoidRight" class="muscle-part">
                <span class="muscle-part-name">三角肌</span>
                <span class="muscle-part-en">Deltoid</span>
                <span class="muscle-part-num">03 個動作</span>
            </a>
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="glute" class="muscle-part">
                <span class="muscle-part-name">臀大肌</span>
                <span class="muscle-part-en">Gluteus Maximus</span>
                <span class="muscle-part-num">02 個動作</span>
            </a>
            <a asp-controller="MuscleMap" asp-action="Index" asp-route-muscle="abs" class="muscle-part">
                <span class="muscle-part-name">腹直肌</span>
                <span class="muscle-part-en">Rectus Abdominis</span>
                <span class="muscle-part-num">03 個動作</span>
            </a>
        </div>
    </div>
</section>

