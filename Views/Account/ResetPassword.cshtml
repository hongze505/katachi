@model katachi.Models.Account.ResetPasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "KATACHI — 重設密碼";
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Cormorant+Garamond:ital,wght@0,300;1,200;1,300&family=Noto+Sans+JP:wght@100;200;300&family=Noto+Serif+JP:wght@200;300;400&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="auth-layout">

        <!-- 左側品牌 -->
        <div class="auth-left-overlay">
            <div class="auth-brand">
                <a class="auth-brand-logo" href="/">
                    KATACH<span class="dumbbell-i">
                    <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                        <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                        <rect x="11" y="20" width="6" height="40" fill="currentColor" />
                        <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                        <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
                    </svg>
                </span>
            </a>
            <span class="auth-brand-sub">形 · Training Encyclopedia</span>
        </div>
        <div class="auth-slogan">
            <div class="auth-slogan-line"></div>
            <p class="auth-slogan-text">
                精準的訓練，<br>始於對身體的理解。<br>每一組動作都應有其意義。
            </p>
        </div>
    </div>

    <!-- 右側表單 -->
    <div class="auth-right">
        <a class="auth-close" href="/" title="回到首頁">
            <span class="auth-close-x"></span>
            Close
        </a>

        <div class="auth-panel show">
            <div class="auth-title">重設密碼</div>
            <div class="auth-subtitle">請輸入你的新密碼</div>

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Token" />

                <div class="form-group">
                    <label class="form-label">新密碼</label>
                    <input asp-for="NewPassword" class="form-input" type="password" placeholder="至少 6 位" />
                    <span asp-validation-for="NewPassword" style="color:#c17f5a;font-size:0.7rem;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">確認新密碼</label>
                    <input asp-for="ConfirmPassword" class="form-input" type="password" placeholder="再輸入一次" />
                    <span asp-validation-for="ConfirmPassword" style="color:#c17f5a;font-size:0.7rem;"></span>
                </div>

                <button type="submit" class="btn-auth"><span>確認重設</span></button>
            </form>

            <div class="auth-switch">
                <a asp-action="Index" class="form-link">返回登入</a>
            </div>
        </div>
    </div>

</div>
</body>
</html>